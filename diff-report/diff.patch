+`timescale 1ns / 1ps
+
+module seg7x16(
+    input clk,
+    input rst,
+    input cs,
+    input [31:0] i_data,
+    output [7:0] o_seg,
+    output [7:0] o_sel
+);
+
+    reg [14:0] cnt;
+    reg [2:0] seg7_addr;
+    reg [7:0] o_sel_r;
+    reg [31:0] i_data_store;
+    reg [7:0] seg_data_r;
+    reg [7:0] o_seg_r;
+
+    wire seg7_clk = cnt[14];
+
+    always @(posedge clk or posedge rst) begin
+        if (rst)
+            cnt <= 15'b0;
+        else
+            cnt <= cnt + 1'b1;
+    end
+
+    always @(posedge seg7_clk or posedge rst) begin
+        if (rst)
+            seg7_addr <= 3'b0;
+        else
+            seg7_addr <= seg7_addr + 1'b1;
+    end
+
+    always @* begin
+        case (seg7_addr)
+        3'd7: o_sel_r = 8'b01111111;
+        3'd6: o_sel_r = 8'b10111111;
+        3'd5: o_sel_r = 8'b11011111;
+        3'd4: o_sel_r = 8'b11101111;
+        3'd3: o_sel_r = 8'b11110111;
+        3'd2: o_sel_r = 8'b11111011;
+        3'd1: o_sel_r = 8'b11111101;
+        default: o_sel_r = 8'b11111110;
+        endcase
+    end
+
+    always @(posedge clk or posedge rst) begin
+        if (rst)
+            i_data_store <= 32'b0;
+        else if (cs)
+            i_data_store <= i_data;
+    end
+
+    always @* begin
+        case (seg7_addr)
+        3'd0: seg_data_r = i_data_store[3:0];
+        3'd1: seg_data_r = i_data_store[7:4];
+        3'd2: seg_data_r = i_data_store[11:8];
+        3'd3: seg_data_r = i_data_store[15:12];
+        3'd4: seg_data_r = i_data_store[19:16];
+        3'd5: seg_data_r = i_data_store[23:20];
+        3'd6: seg_data_r = i_data_store[27:24];
+        default: seg_data_r = i_data_store[31:28];
+        endcase
+    end
+
+    always @(posedge clk or posedge rst) begin
+        if (rst)
+            o_seg_r <= 8'hFF;
+        else begin
+            case (seg_data_r[3:0])
+            4'h0: o_seg_r <= 8'hC0;
+            4'h1: o_seg_r <= 8'hF9;
+            4'h2: o_seg_r <= 8'hA4;
+            4'h3: o_seg_r <= 8'hB0;
+            4'h4: o_seg_r <= 8'h99;
+            4'h5: o_seg_r <= 8'h92;
+            4'h6: o_seg_r <= 8'h82;
+            4'h7: o_seg_r <= 8'hF8;
+            4'h8: o_seg_r <= 8'h80;
+            4'h9: o_seg_r <= 8'h90;
+            4'hA: o_seg_r <= 8'h88;
+            4'hB: o_seg_r <= 8'h83;
+            4'hC: o_seg_r <= 8'hC6;
+            4'hD: o_seg_r <= 8'hA1;
+            4'hE: o_seg_r <= 8'h86;
+            default: o_seg_r <= 8'h8E;
+            endcase
+        end
+    end
+
+    assign o_sel = o_sel_r;
+    assign o_seg = o_seg_r;
+
+endmodule
